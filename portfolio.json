  "coreModules": [
    {
      "module": "Student & Staff Management",
      "description": "Comprehensive database for managing student records, staff profiles, roles, and access permissions",
      "features": [
        "Student registration and profile management",
        "Staff directory with roles and permissions",
        "Class and stream assignment",
        "Document storage and management",
        "Bulk data import/export"
      ],
      "models": ["Student", "Staff", "User", "Class", "Stream", "Subject"]
    },
    {
      "module": "Attendance System",
      "description": "Automated attendance tracking with real-time reporting and analytics",
      "features": [
        "Daily attendance marking",
        "Attendance patterns and analytics",
        "Parent notifications for absences",
        "Attendance reports by period",
        "Bulk attendance operations"
      ],
      "models": ["Attendance", "AttendanceReport"]
    },
    {
      "module": "Examination & Results",
      "description": "Complete exam lifecycle management from scheduling to result publication",
      "features": [
        "Exam creation and scheduling",
        "Marks entry and validation",
        "Grade calculation and assignment",
        "Result publication and access control",
        "Exam analysis and statistics"
      ],
      "models": ["Exam", "ExamResult", "Grades", "GradeComment"]
    },
    {
      "module": "Fees & Payments",
      "description": "Accurate financial tracking with multiple payment methods and comprehensive reporting",
      "features": [
        "Fee structure configuration",
        "Payment tracking and receipting",
        "Arrears monitoring",
        "Payment method integration",
        "Financial reports and reconciliation",
        "Student account balance tracking"
      ],
      "models": ["Fees", "Payment", "FinanceReport"]
    },
    {
      "module": "Communication Hub",
      "description": "Real-time messaging and announcements for school-wide communication",
      "features": [
        "Targeted announcements",
        "Direct messaging",
        "Parent notifications",
        "Announcement history and archiving",
        "Message delivery tracking"
      ],
      "models": ["Message", "Announcement", "Notification"]
    },
    {
      "module": "Timetable Management",
      "description": "Dynamic class and teacher timetable creation with conflict detection",
      "features": [
        "Period scheduling",
        "Subject allocation",
        "Teacher assignment",
        "Room/venue management",
        "Automatic conflict detection",
        "Print-ready timetables"
      ],
      "models": ["Timetable", "Period", "TimeSlot"]
    },
    {
      "module": "Homework & Assignments",
      "description": "Assignment distribution and submission tracking with file management",
      "features": [
        "Create and distribute homework",
        "File upload capabilities",
        "Submission tracking",
        "Due date notifications",
        "Archive and retrieval"
      ],
      "models": ["Homework", "Submission"]
    },
    {
      "module": "Reports & Analytics",
      "description": "Comprehensive reporting system with customizable reports and data export",
      "features": [
        "Academic performance reports",
        "Financial reports",
        "Attendance summaries",
        "Exam statistics",
        "Custom report generation",
        "Data export (PDF, Excel)"
      ],
      "models": ["Report", "ReportCard", "AuditLog"]
    }
  ],

